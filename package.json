{
  "name": "payphone",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/desktop",
    "apps/gateway",
    "apps/mask-proxy",
    "packages/payment-layer"
  ],
  "scripts": {
    "dev": "npm run dev -w @payphone/web",
    "build": "npm run build -w @payphone/web",
    "lint": "npm run lint -w @payphone/web",
    "gateway:dev": "npm run dev -w @payphone/gateway",
    "gateway:start": "npm run start -w @payphone/gateway",
    "circle:setup": "node scripts/circle-setup.mjs",
    "mask-proxy:dev": "npm run dev -w @payphone/mask-proxy",
    "mask-proxy:start": "npm run start -w @payphone/mask-proxy",
    "telephony:dev": "node services/telephony-shim/server.mjs",
    "telephony:haskell": "cd services/telephony-engine && cabal run telephony-engine",
    "escrow:dev": "node services/escrow-shim/server.mjs",
    "escrow:haskell": "cd services/escrow-engine && cabal run escrow-engine",
    "desktop:dev": "npm run tauri dev -w @payphone/desktop",
    "desktop:build": "npm run tauri build -w @payphone/desktop",
    "smoke-test": "node scripts/smoke-test.mjs",
    "services:dev": "node scripts/start-dev-stack.mjs"
  }
}
