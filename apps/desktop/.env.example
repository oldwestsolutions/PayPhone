# Payphone desktop — loads from project root .env when using gateway:dev

# API gateway (Circle keys live on the server, not in the desktop app)
PAYPHONE_API_GATEWAY_URL=http://localhost:4000

# BTCPayServer (required for storage billing)
PAYPHONE_BTCPAY_URL=http://localhost:49392
PAYPHONE_BTCPAY_API_KEY=
PAYPHONE_BTCPAY_STORE_ID=

# Telephony gateway (optional — for live outbound calls)
PAYPHONE_TELEPHONY_URL=
