# Payphone production secrets — copy to .env (never commit .env)

# ── MongoDB (local: docker compose up -d · cloud: MongoDB Atlas) ──
MONGODB_URL=mongodb://localhost:27017/payphone

# ── Supabase (auth + Vercel web signup) ──
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Comma-separated emails that receive admin role (disputes, arbitration)
ADMIN_EMAILS=admin@yourdomain.com

# Vercel (apps/web) — set these in Vercel project env:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# NEXT_PUBLIC_PAYPHONE_GATEWAY_URL=https://api.payphone.cc

# ── Circle Programmable Wallets (LIVE — mainnet) ──
CIRCLE_API_KEY=your-circle-api-key
# Run once: npm run circle:setup (generates + registers entity secret)
CIRCLE_ENTITY_SECRET=
# Optional — auto-created on first wallet signup if empty
CIRCLE_WALLET_SET_ID=
# Mainnet chain for new user wallets (e.g. MATIC, ETH, BASE)
CIRCLE_BLOCKCHAIN=MATIC
# USDC contract on your chain (Polygon native USDC shown)
CIRCLE_USDC_TOKEN_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359
# Platform escrow holding wallet on-chain address
PAYPHONE_ESCROW_WALLET_ADDRESS=
# Circle wallet ID for escrow holding wallet (required for live settlement outflows)
PAYPHONE_ESCROW_WALLET_ID=
# Your business revenue wallet on Circle mainnet — collects platform fees
PAYPHONE_PLATFORM_FEE_WALLET_ADDRESS=
PAYPHONE_PLATFORM_FEE_WALLET_ID=

# ── BTCPayServer — storage billing ($9.99/mo) ──
PAYPHONE_BTCPAY_URL=http://localhost:49392
PAYPHONE_BTCPAY_API_KEY=
PAYPHONE_BTCPAY_STORE_ID=
# Webhook secret from BTCPay store → Webhooks → add https://your-gateway/api/webhooks/btcpay
PAYPHONE_BTCPAY_WEBHOOK_SECRET=

# ── Desktop app service URLs (Circle key stays on gateway) ──
PAYPHONE_API_GATEWAY_URL=http://localhost:4000
PAYPHONE_ESCROW_ENGINE_URL=http://localhost:4004
PAYPHONE_MASK_PROXY_URL=http://localhost:4010
PAYPHONE_TELEPHONY_ENGINE_URL=http://localhost:4010

# false = require Supabase registration (no arbitrary demo logins)
PAYPHONE_DEMO_MODE=false
